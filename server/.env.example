# ─── Server environment ───────────────────────────────────────────────────────
# Copy this file to server/.env and fill in your values.

# Port the Express server listens on
PORT=3001

# Node.js environment: development | production
NODE_ENV=development

# Comma-separated list of CORS-allowed frontend origins.
# In production, set this to your deployed frontend URL.
ALLOWED_ORIGINS=http://localhost:5173

# ─── Resolver settings ────────────────────────────────────────────────────────
# Network timeout (ms) for fetching the TeraBox share page.
# Default is 15 seconds. Raise for slow network paths; lower for faster failures.
RESOLVER_TIMEOUT_MS=15000
