# ─── Frontend (Vite) environment ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# VITE_ prefixed vars are bundled into the client build — do not put secrets here.

# Base URL of your /api backend.
# Omit this (or leave blank) to use same-origin routing (e.g., when frontend
# and backend are served from the same origin behind a reverse proxy).
# For local development with a separate backend process, set to:
VITE_API_BASE_URL=http://localhost:3001
